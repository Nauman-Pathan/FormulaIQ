# Database
DATABASE_URL=postgresql://user:password@localhost:5432/formulaiq
DATABASE_URL_ASYNC=postgresql+asyncpg://user:password@localhost:5432/formulaiq

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# App
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:3000,https://formulaiq.vercel.app

# FastF1 Cache
FASTF1_CACHE_DIR=./cache/fastf1

# ML Model
MODEL_DIR=./ml/models

# API Config
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/formulaiq.log
